mapscripts AlolaIslandMelemele_hns_MapScripts{
        MAP_SCRIPT_ON_TRANSITION{
        setrespawn(HEAL_LOCATION_ALOLA_ISLAND_MELEMELE_HNS)
        }
        MAP_SCRIPT_ON_WARP_INTO_MAP_TABLE[VAR_ALOLA_TRAVEL, 1 {
            applymovement(Alola_Melemele_Captain, moves(face_up))
            applymovement(LOCALID_PLAYER, moves(face_up))
        }]
        MAP_SCRIPT_ON_FRAME_TABLE[VAR_ALOLA_TRAVEL, 1: Alola_Melemele_GetOffBoat]
}

script Alola_Melemele_GetOffBoat{
    lock
    delay(30)
    applymovement(Alola_Melemele_Captain, moves(face_right))
    applymovement(LOCALID_PLAYER, moves(face_left))
    waitmovement(0)
    msgbox("Welcome back to the Isles!

    Come back if you'd like to take a trip
    to mainland Kanto!", MSGBOX_AUTOCLOSE)
    setvar(VAR_ALOLA_TRAVEL, 2)
    release
    end
}

script Alola_Melemele_TravelToKanto{
    lock
    faceplayer
    msgbox("Ahoy!

    Would you like to travel to mainland
    Kanto?", MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES){
        msgbox("Ahoy! Let's get you on board!", MSGBOX_AUTOCLOSE)
        getplayerxy(VAR_TEMP_0, VAR_TEMP_1)
        if (var(VAR_TEMP_1) == 32){
            applymovement(LOCALID_PLAYER, moves(walk_right, walk_down))
            waitmovement(0)
        }
        elif (var(VAR_TEMP_0) == 23 && var(VAR_TEMP_1) == 33){
            applymovement(LOCALID_PLAYER, moves(walk_up, walk_right*2, walk_down))
            waitmovement(0)
        }
        else{}
        applymovement(Alola_Melemele_Captain, moves(face_down))
        applymovement(LOCALID_PLAYER, moves(face_down))
        waitmovement(0)
        fadescreenswapbuffers(FADE_TO_BLACK)
        hidefollower
        playse(SE_EXIT)
        special(SpawnCameraObject)
        hideobjectat(LOCALID_PLAYER, MAP_ALOLA_ISLAND_MELEMELE_HNS)
        hideobjectat(Alola_Melemele_Captain, MAP_ALOLA_ISLAND_MELEMELE_HNS)
        applymovement(OBJ_EVENT_ID_CAMERA, moves(walk_down))
        waitmovement(0)
        waitse
        delay(30)
        fadescreenswapbuffers(FADE_FROM_BLACK)
        playse(SE_RG_SS_ANNE_HORN)
        waitse
        playse(SE_M_SURF)
        applymovement(Alola_Melemele_Ship, moves(walk_left*11))
        delay(90)
        fadescreenswapbuffers(FADE_TO_BLACK)
        special(RemoveCameraObject)
        warp(MAP_ROUTE13_HNS, 37, 29)
        waitstate
        end
    }
    else{
        msgbox("Ahoy!
        Come back when you'd like to set sail.", MSGBOX_AUTOCLOSE)
        release
        end
    }
}

