script Alola_Akala_TotemBattle_Trigger{
    if(!flag(FLAG_TRIGGERED_AKALA_TOTEM))
    {
        if(flag(FLAG_CAUGHT_ALL_AKALA) && flag(FLAG_CAUGHT_ALL_ULAULA) && flag(FLAG_CAUGHT_ALL_PONI) && flag(FLAG_CAUGHT_ALL_MELEMELE))
        {
            lock
            delay(30)
            setvar(VAR_0x8004, 2)
            setvar(VAR_0x8005, 6)
            setvar(VAR_0x8006, 4)
            setvar(VAR_0x8007, 4)
            special(ShakeCamera)
            waitstate
            fadescreenswapbuffers(FADE_TO_BLACK)
            delay(30)
            clearflag(FLAG_HIDE_AKALA_TOTEM)
            gettimeofday
            if ((var(VAR_0x8000)== TIME_MORNING) || (var(VAR_0x8000)== TIME_DAY))
            {
                playmoncry(SPECIES_MAGMORTAR,0)
                setvar(VAR_OBJ_GFX_ID_1, OBJ_EVENT_GFX_SPECIES(MAGMORTAR))
                setflag(FLAG_AKALA_TOTEM_DAY)
                addobject(Akala_Totem)
                waitmoncry
            }
            else
            {
                playmoncry(SPECIES_SALAMENCE,0)
                setvar(VAR_OBJ_GFX_ID_1, OBJ_EVENT_GFX_SPECIES(SALAMENCE))
                clearflag(FLAG_AKALA_TOTEM_DAY)
                addobject(Akala_Totem)
                waitmoncry
            }
            special(DrawWholeMapView)
            delay(30)
            fadescreenswapbuffers(FADE_FROM_BLACK)
            delay(30)
            gettimeofday
            if ((var(VAR_0x8000)== TIME_MORNING) || (var(VAR_0x8000)== TIME_DAY))
            {
                playmoncry(SPECIES_MAGMORTAR,0)
                applymovement(Akala_Totem, moves(walk_in_place_down*2))
                waitmovement(0)
                waitmoncry
            }
            else
            {
                playmoncry(SPECIES_SALAMENCE,0)
                applymovement(Akala_Totem, moves(walk_in_place_down*2))
                waitmovement(0)
                waitmoncry
            }
            setflag(FLAG_TRIGGERED_AKALA_TOTEM)
            release
            end
        }
        else
        {
            end
        }
    }
    else
    {
        end
    }
}

script Alola_Akala_TotemBattle{
    lock
    faceplayer
    if (flag(FLAG_AKALA_TOTEM_DAY))
    {
        playmoncry(SPECIES_MAGMORTAR,0)
        msgbox("Mortaar!", MSGBOX_AUTOCLOSE)
        waitmoncry
        //setwildbattle species:req, level:req, item=ITEM_NONE, species2=SPECIES_NONE, level2=0, item2=ITEM_NONE
        setwildbattle(SPECIES_MAGMAR, 60, ITEM_NONE, SPECIES_MAGMORTAR, 60, ITEM_SITRUS_BERRY)
        settotemboost(B_POSITION_OPPONENT_RIGHT, 1, 1, 1, 1, 1, 1)
        setflag(FLAG_NO_WILD_CATCHING)
        setflag(FLAG_NO_WILD_RUNNING)
        setflag(FLAG_SMART_WILD_AI)
        dowildbattle
        specialvar(VAR_RESULT, GetBattleOutcome)
        if (var(VAR_RESULT) == B_OUTCOME_WON){
            setflag(FLAG_HIDE_AKALA_TOTEM)
            setflag(FLAG_DEFEATED_AKALA_TOTEM)
            removeobject(Akala_Totem)
            msgbox("Totem Magmortar was defeated!
            It scampered off somewhere\.", MSGBOX_AUTOCLOSE)
            clearflag(FLAG_NO_WILD_CATCHING)
            clearflag(FLAG_NO_WILD_RUNNING)
            clearflag(FLAG_SMART_WILD_AI)
            release
            end
        }
    }
    else
    {
        playmoncry(SPECIES_SALAMENCE,0)
        msgbox("Salaa!", MSGBOX_AUTOCLOSE)
        waitmoncry
        setwildbattle(SPECIES_SHELGON, 60, ITEM_NONE, SPECIES_SALAMENCE, 60, ITEM_PETAYA_BERRY)
        settotemboost(B_POSITION_OPPONENT_RIGHT, 1, 1, 1, 1, 1, 1)
        setflag(FLAG_NO_WILD_CATCHING)
        setflag(FLAG_NO_WILD_RUNNING)
        setflag(FLAG_SMART_WILD_AI)
        dowildbattle
        specialvar(VAR_RESULT, GetBattleOutcome)
        if (var(VAR_RESULT) == B_OUTCOME_WON)
        {
            setflag(FLAG_HIDE_AKALA_TOTEM)
            setflag(FLAG_DEFEATED_AKALA_TOTEM)
            removeobject(Akala_Totem)
            msgbox("Totem Salamence was defeated!
            It scampered off somewhere\.", MSGBOX_AUTOCLOSE)
            clearflag(FLAG_NO_WILD_CATCHING)
            clearflag(FLAG_NO_WILD_RUNNING)
            clearflag(FLAG_SMART_WILD_AI)
            release
            end
            }
        if (var(VAR_RESULT) == B_OUTCOME_LOST){
            clearflag(FLAG_NO_WILD_CATCHING)
            clearflag(FLAG_NO_WILD_RUNNING)
            clearflag(FLAG_SMART_WILD_AI)
            release
            end
        }
    }
}

script Alola_Akala_Totem_sign{
    lock
    if(flag(FLAG_BATTLED_TAPU_FINI) && flag(FLAG_BATTLED_TAPU_KOKO) && flag(FLAG_BATTLED_TAPU_BULU) && flag(FLAG_BATTLED_TAPU_LELE))
    {
        msgbox("The totem is emanating a strong
        energy\.
        
        Touch the totem to teleport to another
        Isle?")
        dynmultichoice(20, 4, FALSE, 4, 0, DYN_MULTICHOICE_CB_NONE,"Melemele Isle", "Akala Isle", "Ula'ula Isle", "Poni Isle", "Cancel")
        if (var(VAR_RESULT) == 0)
        {
            warp(MAP_MELEMELE_ISLE_HNS, 34, 26)
            waitstate
            end
        }
        if (var(VAR_RESULT) == 1)
        {
            warp(MAP_AKALA_ISLE_HNS, 9, 10)
            waitstate
            end
        }
        if (var(VAR_RESULT) == 2)
        {
            warp(MAP_ULA_ULA_FOREST_HNS, 16, 5)
            waitstate
            end
        }
        if (var(VAR_RESULT) == 3)
        {
            warp(MAP_PONI_ISLE_HNS, 13, 8)
            waitstate
            end
        }
        else
        {
            release
            end
        }

    }
    else
    {
        msgbox("A strange totem stands here,
        power is emanating from it\.", MSGBOX_AUTOCLOSE)
    }
    release
    end
}

script Alola_Akala_TapuLele_Flyover{
    if(flag(FLAG_FLYOVER_TAPU_LELE))
    {
        addobject(Akala_Flyover_Tapu)
        playse(SE_M_FLY)
        applymovement(Akala_Flyover_Tapu, moves(walk_faster_left*17))
        waitmovement(0)
        removeobject(Akala_Flyover_Tapu)
        clearflag(FLAG_FLYOVER_TAPU_LELE)
        clearflag(FLAG_HIDE_TAPU_LELE)
        release
        end

    }
    release
    end
}

script Alola_Akala_BattleVsTapuLele{
    lock
    faceplayer
    playmoncry(SPECIES_TAPU_LELE, CRY_MODE_ENCOUNTER)
    msgbox("Le-Lele!")
    waitmoncry
    seteventmon(SPECIES_TAPU_LELE, 60)
    special(BattleSetup_StartLegendaryBattle)
    waitstate
    specialvar(VAR_RESULT, GetBattleOutcome)
    if (var(VAR_RESULT) == B_OUTCOME_CAUGHT){
        setflag(FLAG_HIDE_TAPU_LELE)
        setflag(FLAG_BATTLED_TAPU_LELE)
        removeobject(Akala_Tapu)
        release
        end
    }
    elif (var(VAR_RESULT) == B_OUTCOME_WON){
        setflag(FLAG_HIDE_TAPU_LELE)
        setflag(FLAG_BATTLED_TAPU_LELE)
        removeobject(Akala_Tapu)
        release
        end
    }
    else{
        release
        end
    }
    release
    end
}

