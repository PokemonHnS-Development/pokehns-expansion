mapscripts Akala_House_hns_MapScripts{}

script Alola_Akala_House_OldWoman{
    lock
    faceplayer
    msgbox("I tell my husband everyday not to feed
    the Chatot, but he never listens!
    
    One day he'll bring one of those darn
    things home, I just know it!", MSGBOX_AUTOCLOSE)
    release
    end
}