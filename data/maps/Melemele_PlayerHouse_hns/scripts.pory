                                            msgbox("Let me take a look at your Pok\edex{PAUSE 15}.{PAUSE 15}.{PAUSE 15}.",MSGBOX_AUTOCLOSE)
                                            playse(SE_PIN)
                                            applymovement(SamsonOakVilla, moves(emote_exclamation_mark))
                                            waitmovement(0)
                                            msgbox("Wow, {PLAYER}!")
                                            playfanfare(MUS_HG_OBTAIN_EGG)
                                            msgbox("You found all the Alolan variants living
