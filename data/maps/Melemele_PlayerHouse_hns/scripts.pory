            }
            msgbox("Let me take a look at your Pok\edex{PAUSE 15}.{PAUSE 15}.{PAUSE 15}.
            
            It seems you haven't quite found all of
            the Alolan variants on Melemele Isle
            just yet.
            
            I've heard Melemele Isle has {COLOR RED}4 {COLOR DARK_GRAY}Alolan
            variants for you to find\.

            {COLOR RED}Rattata{COLOR DARK_GRAY}, {COLOR RED}Raticate{COLOR DARK_GRAY}, {COLOR RED}Meowth{COLOR DARK_GRAY}, and {COLOR RED}Persian{COLOR DARK_GRAY}.

            Keep on searching and come back when
            you've caught them all!",MSGBOX_AUTOCLOSE)
            release
            end
        }
        elif (var(VAR_RESULT)==1){
